{
  "name": "patchup",
  "version": "0.2.1",
  "description": "Automatically update the packages in your projects",
  "bin": {
    "patchup": "./dist/index.js"
  },
  "scripts": {
    "build": "rm -rf dist && tsc && chmod +x dist/index.js",
    "dev": "tsc -w",
    "test": "tsc --noEmit && biome check . && vitest run src",
    "prepublishOnly": "npm test && npm run build"
  },
  "keywords": [
    "update",
    "upgrade",
    "dependencies",
    "dependency-management",
    "packages",
    "outdated",
    "automation",
    "cli",
    "testing"
  ],
  "author": "Anders Windelhed",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/andwin/patchup.git"
  },
  "packageManager": "pnpm@10.20.0",
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "chalk": "^5.6.2",
    "command-line-args": "^6.0.2",
    "command-line-usage": "^7.0.4",
    "execa": "^9.6.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@types/command-line-args": "^5.2.3",
    "@types/command-line-usage": "^5.0.4",
    "@types/node": "^25.9.3",
    "typescript": "^5.9.3",
    "vitest": "4.1.9"
  }
}
